# vault-setup — Environment Variables
# Populate before running any scripts. Run scripts in order 01–07.

# Solana RPC
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Keypairs — generate with: solana-keygen new --outfile admin.json
# Store as JSON arrays: [1,2,3,...,64]
ADMIN_KEYPAIR=[...]
MANAGER_KEYPAIR=[...]
VAULT_KEYPAIR=[...]   # new keypair for the vault account itself

# Token addresses
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# LP token metadata URI — upload metadata.json to IPFS/CDN first
METADATA_URI=https://your-cdn.com/osprey-lp-metadata.json

# Populated after running scripts:
VAULT_ADDRESS=                  # output of 01-create-vault.ts
KAMINO_STRATEGY_ADDRESS=        # output of 05-init-kamino-strategy.ts
TRUSTFUL_STRATEGY_ADDRESS=      # output of 06-init-trustful-strategy.ts
HL_DEPOSIT_WALLET=              # Solana pubkey linked to your HL EVM wallet

# Adaptor IDs — verify from https://docs.ranger.finance/security/deployed-programs
KAMINO_ADAPTOR_PROGRAM_ID=
TRUSTFUL_ADAPTOR_PROGRAM_ID=

# Kamino addresses — verify from https://app.kamino.finance and kamino-scripts repo
KAMINO_LENDING_MARKET=
KAMINO_RESERVE=
