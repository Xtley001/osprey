# Keeper Bot — Environment Variables
# Copy to .env and fill in real values before deploying

# Solana RPC (Helius recommended — get free key at helius.dev)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Solana keypairs — JSON arrays from `solana-keygen new`
# NEVER commit these to git. Use Render env vars in production.
ADMIN_KEYPAIR=[1,2,3,...]
MANAGER_KEYPAIR=[1,2,3,...]

# On-chain addresses — populated after running vault-setup scripts
VAULT_ADDRESS=
KAMINO_STRATEGY_ADDRESS=
TRUSTFUL_STRATEGY_ADDRESS=

# Standard addresses (safe to keep as-is)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
HL_API_URL=https://api.hyperliquid.xyz
OSPREY_API_URL=https://osprey-three.vercel.app

# Hyperliquid EVM wallet (for signing orders)
HL_PRIVATE_KEY=0x...
HL_WALLET_ADDRESS=0x...

# Databases
DATABASE_URL=postgresql://user:pass@host:5432/dbname
REDIS_URL=redis://default:password@host:port

# Adaptor program IDs — verify from docs.ranger.finance/security/deployed-programs
# DO NOT fill these in from AI suggestions — verify from the live docs
KAMINO_ADAPTOR_PROGRAM_ID=
TRUSTFUL_ADAPTOR_PROGRAM_ID=

# Kamino pool addresses — verify from voltrxyz/kamino-scripts repo
KAMINO_COUNTER_PARTY_TA=
KAMINO_COUNTER_PARTY_TA_AUTH=
KAMINO_PROTOCOL_PROGRAM=
KAMINO_LENDING_MARKET=
KAMINO_RESERVE=
